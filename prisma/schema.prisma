generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ==========================================
// THE MONOPOLY MODELS
// ==========================================

// Tabla para la sala de juego
model GameSession {
  id                String            @id @default(uuid())
  roomCode          String            @unique
  isActive          Boolean           @default(true)
  freeParkingAmount Int               @default(0) // El pozo acumulado opcional
  createdAt         DateTime          @default(now())
  
  // Relaciones
  players           Player[]
  transactions      TransactionLog[]
  paymentRequests   PaymentRequest[]
}

// Tabla para los jugadores de la partida
model Player {
  id            String      @id @default(uuid())
  name          String
  pin           String      @default("0000")  
  balance       Int         @default(1500)
  isHost        Boolean     @default(false)
  createdAt     DateTime    @default(now())
  
  // Llave foránea para vincular al jugador con su sala
  gameSessionId String
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
}

// Tabla para el historial inmutable de movimientos de dinero
model TransactionLog {
  id            String      @id @default(uuid())
  amount        Int
  senderId      String?     // Puede ser nulo si el dinero viene del Banco
  receiverId    String?     // Puede ser nulo si el dinero va al Banco
  timestamp     DateTime    @default(now())
  
  // Llave foránea
  gameSessionId String
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
}

// Tabla para solicitudes de pago / cobros
model PaymentRequest {
  id            String      @id @default(uuid())
  amount        Int
  requesterId   String      // Quien pide el dinero
  targetPlayerId String     // A quien se le cobra (un jugador específico)
  status        String      @default("PENDING") // PENDING, PAID, REJECTED
  createdAt     DateTime    @default(now())

  // Llave foránea
  gameSessionId String
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
}


// ==========================================
// THE CHAMELEON MODELS
// ==========================================

model ChameleonSession {
  id              String            @id @default(cuid())
  roomCode        String            @unique
  status          String            @default("lobby") // 'lobby', 'playing', 'voting', 'results'
  category        String?           
  secretWord      String?           
  chameleonId     String?           
  
  // NUEVOS CAMPOS PARA EL MOTOR DE RONDAS
  maxVotesAllowed Int               @default(1) // El Host lo configura (1, 2, o 3)
  votesUsed       Int               @default(0) // Cuántas votaciones han gastado
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  players         ChameleonPlayer[]
  votes           ChameleonVote[]   // Registro de votos emitidos
}

model ChameleonPlayer {
  id              String           @id @default(cuid())
  name            String
  pin             String
  isHost          Boolean          @default(false)
  isParticipating Boolean          @default(true) // Si es false, es solo el Referí/Host
  score           Int              @default(0)
  hasVoted        Boolean          @default(false)
  
  sessionId       String
  session         ChameleonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  votesCast       ChameleonVote[]  @relation("Voter")
  votesReceived   ChameleonVote[]  @relation("VotedTarget")
  
  createdAt       DateTime         @default(now())
}

model ChameleonVote {
  id              String           @id @default(cuid())
  sessionId       String
  session         ChameleonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  voterId         String
  voter           ChameleonPlayer  @relation("Voter", fields: [voterId], references: [id])
  
  votedTargetId   String
  votedTarget     ChameleonPlayer  @relation("VotedTarget", fields: [votedTargetId], references: [id])
  
  createdAt       DateTime         @default(now())
  
  @@unique([sessionId, voterId]) // Un jugador solo puede emitir un voto por ronda
}